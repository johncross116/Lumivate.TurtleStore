<h3>Are you sure you want to delete this turtle?</h3>

<div class="card" style="width: 24rem;">
    <div class="card-body">
        <h5 class="card-title">@Model.Name</h5>
        <p class="card-text">
            <strong>Species:</strong> @Model.Species <br />
            <strong>Price:</strong> $@Model.Price <br />
            <strong>Available:</strong> @(Model.IsAvailable ? "Yes" : "No")
        </p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
